---
import Layout from '../layouts/Layout.astro';
import PipelineDiagram from '../components/PipelineDiagram.astro';
import EngagementsBlock from '../components/EngagementsBlock.astro';
import ArticleCard from '../components/ArticleCard.astro';
import { getCollection } from 'astro:content';

const writing = await getCollection('writing');
const featuredWriting = writing.slice(0, 3);
---
<Layout title="Aaghran Ghosh — Principal PM · AI Builder" description="Principal PM at ThoughtSpot, building Spotter — natural language search and agentic analytics for enterprises. I also build my own AI products.">

  <!-- Hero -->
  <section class="max-w-4xl mx-auto px-6 pt-20 pb-16 border-b border-line">
    <div class="grid md:grid-cols-[1fr_auto] gap-12 items-start">
      <!-- Left: copy -->
      <div class="max-w-xl">
        <p class="text-[10px] text-accent font-bold tracking-[0.2em] uppercase mb-5">
          Principal PM · AI Builder · Bangalore
        </p>
        <h1 class="text-5xl font-black text-ink tracking-tightest leading-[1.02] mb-6">
          I build AI products<br/>that work in production.
        </h1>
        <p class="text-sm text-ink-muted leading-relaxed mb-8">
          Principal PM at ThoughtSpot, building Spotter — natural language search and agentic
          analytics for enterprises. I work at the intersection of NLS, causal analytics, and
          agentic AI product development. Outside the day job, I build my own AI products —
          travel tech, content pipelines, internal tools — because shipping is how I think.
        </p>
        <div class="flex items-center gap-4 flex-wrap">
          <a href="#work" class="text-xs bg-ink text-canvas px-4 py-2 rounded-lg hover:opacity-80 transition-opacity">
            See what I've built ↓
          </a>
          <span class="text-xs text-ink-muted">
            or email <a href="mailto:aaghran@gmail.com" class="text-accent font-semibold hover:underline">aaghran@gmail.com</a>
          </span>
        </div>
      </div>

      <!-- Right: what I actually build -->
      <div class="hidden md:flex flex-col gap-3 pt-2 min-w-[200px]">
        <div class="bg-surface border border-accent-ring rounded-xl px-4 py-3">
          <p class="text-[9px] text-accent font-bold tracking-[0.15em] uppercase mb-1">Day job</p>
          <p class="text-sm font-bold text-ink">Spotter</p>
          <p class="text-[11px] text-ink-muted">NLS · Causal analytics · Enterprise AI</p>
        </div>
        <div class="bg-surface border border-line rounded-xl px-4 py-3">
          <p class="text-[9px] text-ink-muted font-bold tracking-[0.15em] uppercase mb-1">Side builds</p>
          <div class="flex flex-col gap-1.5">
            <div>
              <p class="text-sm font-bold text-ink">WanderingBong</p>
              <p class="text-[11px] text-ink-muted">AI publishing pipeline · Production</p>
            </div>
            <div class="border-t border-line pt-1.5">
              <p class="text-sm font-bold text-ink">Roami</p>
              <p class="text-[11px] text-ink-muted">Travel journaling app · React Native</p>
            </div>
          </div>
        </div>
        <div class="bg-surface border border-line rounded-xl px-4 py-3">
          <p class="text-[9px] text-ink-muted font-bold tracking-[0.15em] uppercase mb-1">Stack</p>
          <p class="text-[11px] text-ink-muted leading-relaxed">Claude API · MCP · Node.js · Supabase · React Native</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Currently strip -->
  <div class="bg-accent-subtle border-b border-accent-ring">
    <div class="max-w-4xl mx-auto px-6 py-3 flex items-center gap-4 flex-wrap">
      <span class="text-[10px] text-accent font-bold tracking-[0.15em] uppercase shrink-0">Currently</span>
      <div class="w-px h-4 bg-accent-ring shrink-0"></div>
      <p class="text-xs text-ink">
        Principal PM @ <strong>ThoughtSpot</strong> — leading Spotter, natural language search and agentic analytics for enterprises
      </p>
      <span class="ml-auto text-[10px] bg-green-100 dark:bg-green-900/30 text-green-700 dark:text-green-400 px-2.5 py-1 rounded-full font-semibold whitespace-nowrap">
        ● Active
      </span>
    </div>
  </div>

  <!-- Selected Work -->
  <section id="work" class="max-w-4xl mx-auto px-6 py-16">
    <p class="text-[10px] text-ink-muted tracking-[0.25em] uppercase mb-10">Selected Work</p>

    <!-- 01 Spotter — leads now -->
    <div class="pb-12 border-b border-line mb-12">
      <div class="flex items-start justify-between gap-6 flex-wrap mb-4">
        <div>
          <p class="text-[10px] text-ink-muted mb-3 tracking-wide">01 — Enterprise AI · Principal PM</p>
          <h2 class="text-2xl font-black text-ink tracking-tightest mb-4">Spotter @ ThoughtSpot</h2>
        </div>
        <span class="text-[10px] bg-ink text-canvas px-3 py-1.5 rounded-full font-semibold whitespace-nowrap self-start mt-1">
          ● Live · Enterprise
        </span>
      </div>
      <p class="text-sm text-ink-muted leading-relaxed max-w-2xl">
        Natural language search and agentic analytics for enterprises — letting users ask questions
        of their data in plain English and get governed, trustworthy answers. I own the NLS
        reasoning layer, the agentic workflow model, and the MCP integration layer.
      </p>
    </div>

    <!-- 02 WanderingBong -->
    <div class="grid md:grid-cols-2 gap-8 pb-12 border-b border-line mb-12 items-start">
      <div>
        <p class="text-[10px] text-ink-muted mb-3 tracking-wide">02 — AI Pipeline · Production</p>
        <h2 class="text-2xl font-black text-ink tracking-tightest mb-4">WanderingBong</h2>
        <p class="text-sm text-ink-muted leading-relaxed mb-5">
          My slow-travel blog, rebuilt around a custom AI publishing pipeline.
          Telegram capture → Railway → Claude API → Supabase CMS → published post.
          Three microservices, custom MCP server, running on EC2 in production.
        </p>
        <div class="flex flex-wrap gap-2 mb-5">
          {['MCP', 'Claude API', 'Node.js', 'Supabase', 'Railway'].map(t => (
            <span class="text-[10px] bg-accent-subtle border border-accent-ring text-accent px-2 py-0.5 rounded-full">{t}</span>
          ))}
        </div>
        <a href="/projects/wanderingbong" class="text-sm text-accent font-bold hover:underline">
          Read the full story →
        </a>
      </div>
      <div class="bg-surface border border-line rounded-xl p-5">
        <p class="text-[9px] text-ink-muted tracking-[0.15em] uppercase mb-3">Publishing pipeline</p>
        <PipelineDiagram />
      </div>
    </div>

    <!-- More projects link -->
    <a href="/projects" class="text-sm text-accent font-bold hover:underline">
      View all projects — Roami, Eidetic, Lyaadh →
    </a>
  </section>

  <!-- Engagements -->
  <section class="max-w-4xl mx-auto px-6 pb-16">
    <EngagementsBlock />
  </section>

  <!-- Writing preview -->
  <section class="max-w-4xl mx-auto px-6 pb-20 border-t border-line pt-16">
    <p class="text-[10px] text-ink-muted tracking-[0.25em] uppercase mb-8">Writing</p>
    <div class="grid sm:grid-cols-3 gap-4 mb-6">
      {featuredWriting.map(w => (
        <ArticleCard
          title={w.data.title}
          meta={w.data.meta}
          url={w.data.url}
          image={w.data.image}
        />
      ))}
    </div>
    <a href="https://aaghran.substack.com" target="_blank" rel="noreferrer"
      class="text-sm text-accent font-bold hover:underline">
      All writing on Substack →
    </a>
  </section>

</Layout>
